<script>
// ===== 設定 =====
const WEBHOOK_TOKEN = 'https://nickleo9.zeabur.app/webhook/threads-exchange-token';
const WEBHOOK_2FA   = 'https://nickleo9.zeabur.app/webhook/get-2fa';
const PUSHCUT_URL   = 'https://api.pushcut.io/1WGcUv9DUIqIVGrmLVrUl/notifications/My%20ip';

// ===== 狀態 =====
let otpCountdown = null;
let currentOTP = '';

// ===== 帳號變更 =====
function onAccountChange() {
  const name = document.getElementById('accountName').value.trim();
  const btn = document.getElementById('btn2fa');
  btn.disabled = !name;
  // 帳號改變時清掉舊 OTP
  clearOTP();
}

function clearOTP() {
  if (otpCountdown) clearInterval(otpCountdown);
  document.getElementById('otpDigits').style.display = 'none';
  document.getElementById('otpPlaceholder').style.display = 'block';
  document.getElementById('otpPlaceholder').textContent = '先輸入帳號名稱';
  document.getElementById('otpTimer').style.display = 'none';
  document.getElementById('progressFill').style.width = '0%';
  currentOTP = '';
}

// ===== 取得 2FA =====
async function fetch2FA() {
  const account = document.getElementById('accountName').value.trim();
  if (!account) return;

  const btn = document.getElementById('btn2fa');
  const btnText = document.getElementById('btn2faText');
  btn.disabled = true;
  btnText.textContent = '讀取中';
  btnText.className = 'loading';

  try {
    const res = await fetch(`${WEBHOOK_2FA}?account=${encodeURIComponent(account)}`);
    const data = await res.json();

    if (data.otp) {
      showOTP(data.otp);
      startOTPTimer();
    } else {
      showOTPError(data.message || '取得失敗，請確認帳號名稱');
    }
  } catch(e) {
    showOTPError('連線失敗：' + e.message);
  } finally {
    btn.disabled = false;
    btnText.textContent = '重新取得';
    btnText.className = '';
  }
}

function showOTP(otp) {
  currentOTP = otp;
  document.getElementById('otpPlaceholder').style.display = 'none';
  const digits = document.getElementById('otpDigits');
  digits.style.display = 'block';
  digits.textContent = otp;
  digits.className = 'otp-digits';
  document.getElementById('otpTimer').style.display = 'block';
  document.getElementById('step1Num').className = 'step-num done';
  document.getElementById('step1Num').textContent = '✓';
}

function showOTPError(msg) {
  document.getElementById('otpPlaceholder').style.display = 'block';
  document.getElementById('otpPlaceholder').textContent = '❌ ' + msg;
  document.getElementById('otpDigits').style.display = 'none';
}

function startOTPTimer() {
  if (otpCountdown) clearInterval(otpCountdown);

  otpCountdown = setInterval(() => {
    const now = Math.floor(Date.now() / 1000);
    const remaining = 30 - (now % 30);
    const pct = (remaining / 30) * 100;

    const timerEl = document.getElementById('otpTimer');
    const fillEl  = document.getElementById('progressFill');
    const digits  = document.getElementById('otpDigits');

    timerEl.textContent = `${remaining} 秒後更新`;
    fillEl.style.width = pct + '%';
    fillEl.className = 'progress-fill' +
      (remaining <= 5 ? ' danger' : remaining <= 10 ? ' warning' : '');

    if (remaining === 30) {
      // 新的30秒週期 → 自動重新取得
      digits.className = 'otp-digits expired';
      fetch2FA();
    }
  }, 1000);
}

// ===== 換取 Token =====
async function submitToken() {
  const account    = document.getElementById('accountName').value.trim();
  const shortToken = document.getElementById('shortToken').value.trim().replace(/\s+/g, '');
  const resultBox  = document.getElementById('tokenResult');
  const btn        = document.getElementById('btnToken');
  const btnText    = document.getElementById('btnTokenText');

  if (!account)    return showTokenResult('error', '請輸入帳號名稱');
  if (!shortToken) return showTokenResult('error', '請貼上短期 Token');

  btn.disabled = true;
  btnText.textContent = '處理中';
  btnText.className = 'loading';
  resultBox.className = 'result';

  try {
    const res = await fetch(WEBHOOK_TOKEN, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ account, short_token: shortToken })
    });
    const data = await res.json();

    if (data.success) {
      showTokenResult('success', data);
      document.getElementById('shortToken').value = '';
      document.getElementById('step2Num').className = 'step-num done';
      document.getElementById('step2Num').textContent = '✓';
    } else {
      showTokenResult('error', data.message || '發生錯誤');
    }
  } catch(e) {
    showTokenResult('error', '連線失敗：' + e.message);
  } finally {
    btn.disabled = false;
    btnText.textContent = '換取60天Token + 取得ID';
    btnText.className = '';
  }
}

function showTokenResult(type, data) {
  const box = document.getElementById('tokenResult');
  if (type === 'success') {
    box.className = 'result success';
    box.innerHTML = `
      <div style="font-weight:bold;margin-bottom:8px;">✅ 已自動存入 Sheets！</div>
      <div class="result-row">
        <span class="result-key">帳號</span>
        <span class="result-val">${data.account}</span>
      </div>
      <div class="result-row">
        <span class="result-key">Threads ID</span>
        <span class="result-val" onclick="copy('${data.threadsId}')" title="點擊複製">
          ${data.threadsId} 📋
        </span>
      </div>
      <div class="result-row">
        <span class="result-key">Token到期</span>
        <span class="result-val">${data.expiryDate || '60天後'}</span>
      </div>
      <div class="result-row">
        <span class="result-key">狀態</span>
        <span class="result-val">等待測試 ✓</span>
      </div>
    `;
  } else {
    box.className = 'result error';
    box.innerHTML = `<b>❌ 錯誤</b><br><span style="font-size:11px">${data}</span>`;
  }
}

// ===== 換 IP =====
async function triggerIP() {
  const status = document.getElementById('ipStatus');
  status.textContent = '📡 發送中...';
  status.className = 'ip-status triggered';

  try {
    await fetch(PUSHCUT_URL, { mode: 'no-cors' });
    status.textContent = '✅ 捷徑已觸發！手機正在換IP，記得重新連熱點';
    status.className = 'ip-status done';
    document.getElementById('step3Num').className = 'step-num done';
    document.getElementById('step3Num').textContent = '✓';

    // 30秒後提醒重置
    setTimeout(() => {
      status.textContent = '準備好了嗎？可繼續下一個帳號 👆';
      status.className = 'ip-status';
      // 重置步驟標記
      ['step1Num','step2Num','step3Num'].forEach(id => {
        document.getElementById(id).className = 'step-num';
        document.getElementById(id).textContent = id.replace('step','').replace('Num','');
      });
      document.getElementById('tokenResult').className = 'result';
      document.getElementById('accountName').value = '';
      document.getElementById('accountName').focus();
      clearOTP();
    }, 30000);
  } catch(e) {
    status.textContent = '❌ 觸發失敗：' + e.message;
    status.className = 'ip-status';
  }
}

function copy(text) {
  navigator.clipboard.writeText(text)
    .then(() => alert('已複製：' + text))
    .catch(() => {});
}

// Ctrl+Enter 送出 Token
document.addEventListener('keydown', e => {
  if (e.ctrlKey && e.key === 'Enter') submitToken();
});
</script>
</body>
</html>
